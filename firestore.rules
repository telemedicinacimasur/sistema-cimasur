rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Ventas en Consignación Lotes
    match /crm_consignacion_lotes/{loteId} {
      allow read, write: if isSignedIn();

      // Subcolección de movimientos por periodo
      match /movimientos/{periodoId} {
        allow read, write: if isSignedIn();
      }
    }

    // Ventas en Consignación Precios pactados
    match /crm_consignacion_precios/{precioId} {
      allow read, write: if isSignedIn();
    }
  }
}
